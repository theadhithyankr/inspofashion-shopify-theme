{% liquid
  assign max_items = section.settings.max_products

  if section.settings.collection != blank and shop.products_count != 0
    assign section_products = section.settings.collection.products
    assign max_items = section_products.size | at_most: section.settings.max_products
    assign total_products = section_products.size
  else
    assign total_products = 0
  endif

  # Check if we should show "View all" button
  assign show_view_all = false
  if section.settings.show_view_all_button and section.settings.collection != blank and total_products > max_items
    assign show_view_all = true
  endif

  case section.settings.layout_type
    when 'grid'
      assign classes = 'resource-list--grid'
      capture styles
        echo '--resource-list-column-gap-desktop: ' | append: section.settings.columns_gap | append: 'px;'
        echo '--resource-list-row-gap-desktop: ' | append: section.settings.rows_gap | append: 'px;'
        echo '--resource-list-columns: repeat(' | append: section.settings.columns | append: ', 1fr);'
        echo '--resource-list-columns-mobile: repeat(' | append: section.settings.mobile_columns | append: ', 1fr);'
      endcapture
    when 'carousel'
      assign classes = 'resource-list__carousel'
      capture styles
        echo '--resource-list-column-gap-desktop: ' | append: section.settings.columns_gap | append: 'px;'
        echo '--column-count: ' | append: section.settings.columns | append: ';'
        echo '--column-count-mobile: ' | append: section.settings.mobile_columns | append: ';'
      endcapture
  endcase
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  id="ProductListSection-{{ section.id }}"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
    {% if request.design_mode == false and section.settings.collection == blank %}
      in-onboarding-state
    {% endif %}
  "
  style="
    --column-count-mobile: {{ section.settings.mobile_columns }};
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
    {{ styles }}
  "
>
  <div class="section-resource-list__header">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture list_items %}
    {% for i in (1..max_items) %}
      {% if section_products.size > 0 %}
        {% assign index = forloop.index0 %}
        {% assign product = section_products[index] %}
      {% else %}
        {% assign product = null %}
      {% endif %}
      <div
        class="resource-list__item"
      >
        {% content_for 'block', type: 'product-card', id: 'static-product-card', closest.product: product %}
      </div>

      {% unless forloop.last %}
        <!--@list/split-->
      {% endunless %}

    {% endfor %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  <div
    class="
      resource-list
      {% if section.settings.layout_type == 'carousel' %}
        force-full-width
      {% endif %}
      {% if section.settings.carousel_on_mobile and section.settings.layout_type != 'carousel' %}
        hidden--mobile
      {% endif %}
      {{ classes }}
    "
    style="{{ styles }}"
    {% if section.settings.layout_type == 'grid' %}
      data-testid="resource-list-grid"
    {% endif %}
  >
    {% case section.settings.layout_type %}
      {% when 'grid' %}
        {{ list_items }}
      {% when 'carousel' %}
        {% render 'resource-list-carousel',
          ref: 'resourceListCarousel',
          slides: list_items_array,
          slide_count: max_items,
          settings: section.settings
        %}
      {% when 'editorial' %}
        {% render 'editorial-product-grid', items: list_items_array %}
    {% endcase %}
  </div>

  {% if section.settings.carousel_on_mobile and section.settings.layout_type != 'carousel' %}
    {% liquid
      assign mobile_carousel_gap = section.settings.columns_gap
    %}
    <div
      class="
        resource-list
        hidden--desktop
        force-full-width
      "
      style="
        --resource-list-column-gap-desktop: {{ mobile_carousel_gap }}px;
        --column-count: {{ section.settings.columns }};
      "
    >
      {% render 'resource-list-carousel',
        ref: 'resourceListCarouselMobile',
        slides: list_items_array,
        slide_count: max_items,
        settings: section.settings
      %}
    </div>
  {% endif %}

  {% comment %} View All Button Section {% endcomment %}
  {% if show_view_all %}
    <div
      class="section-resource-list__view-all color-{{ section.settings.color_scheme }}"
      style="text-align: {{ section.settings.view_all_alignment }}; "
    >
      <a
        href="{{ section.settings.collection.url }}"
        class="btn {{ section.settings.view_all_style }}"
        style="border-radius: {{ section.settings.view_all_radius }}px;"
        {% if section.settings.view_all_open_new_tab %}
          target="_blank" rel="noopener"
        {% endif %}
      >
        {{ section.settings.view_all_text | default: 'View all' }}
        {% if section.settings.view_all_show_count %}
          <span class="product-count">({{ total_products }})</span>
        {% endif %}
      </a>
    </div>
  {% endif %}

  <div
    class="section-resource-list__content"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {%- content_for 'blocks' -%}
  </div>
</div>
{% stylesheet %}
  /* Base button styles */
  .btn {
    display: inline-block;
    padding: 12px 24px;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  /* Primary Button */
  .btn.btn--primary {
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
    border: 1px solid var(--color-primary-button-border);
  }
  .btn.btn--primary:hover {
    background: var(--color-primary-button-hover-background);
    color: var(--color-primary-button-hover-text);
    border-color: var(--color-primary-button-hover-border);
  }

  /* Secondary Button */
  .btn.btn--secondary {
    background: var(--color-secondary-button-background);
    color: var(--color-secondary-button-text);
    border: 1px solid var(--color-secondary-button-border);
  }
  .btn.btn--secondary:hover {
    background: var(--color-secondary-button-hover-background);
    color: var(--color-secondary-button-hover-text);
    border-color: var(--color-secondary-button-hover-border);
  }

  /* Outline Button */
  .btn.btn--outline {
    background: transparent;
    color: var(--color-secondary-button-text);
    border: 1px solid var(--color-secondary-button-border);
  }
  .btn.btn--outline:hover {
    background: var(--color-secondary-button-hover-background);
    color: var(--color-secondary-button-hover-text);
    border-color: var(--color-secondary-button-hover-border);
  }

  /* Link Button */
  .btn.link {
    background: transparent;
    color: var(--color-primary);
    text-decoration: underline;
    padding: 0;
    border: none;
  }  
  {% endstylesheet %}
  
<style>
    #ProductListSection-{{ section.id }} .resource-list__carousel .resource-list__slide  {
      max-width: 450px;
    }

    @media (min-width: 750px) {
        #ProductListSection-{{ section.id }} .resource-list__carousel .resource-list__slide  {
         max-width: calc((100% - ({{section.settings.columns_gap}}px * ({{ section.settings.desktop_columns_carousel | default: 3 }} - 1))) / {{ section.settings.desktop_columns_carousel | default: 3 }});
      }
    }

    @media (max-width: 749px) {
       #ProductListSection-{{ section.id }} .resource-list__carousel .resource-list__slide  {
        max-width: calc((100% - ({{section.settings.columns_gap}}px * ({{ section.settings.mobile_columns_carousel | default: 1 }} - 1))) / {{ section.settings.mobile_columns_carousel | default: 1 }});
      }
    }

</style>
