<div class="section-testimonials-atelier color-{{ section.settings.color_scheme }}" id="testimonials-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="testimonials-atelier__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="testimonials-atelier__carousel">
      <div class="testimonials-atelier__container">
        <div class="testimonials-atelier__track" id="testimonials-track-{{ section.id }}">
          {% for block in section.blocks %}
            <div class="testimonial-atelier-card" {{ block.shopify_attributes }}>
              <blockquote class="testimonial-quote" style="
                {% if block.settings.type_preset == 'custom' %}
                  font-family: {{ block.settings.font }};
                  font-size: {{ block.settings.font_size }};
                {% else %}
                  font-family: var(--font-{{ block.settings.type_preset }}--family);
                {% endif %}
                {% if block.settings.line_height %}line-height: var(--line-height-{{ block.settings.line_height }});{% endif %}
                {% if block.settings.letter_spacing %}letter-spacing: var(--letter-spacing-{{ block.settings.letter_spacing }});{% endif %}
                {% if block.settings.case == 'uppercase' %}text-transform: uppercase;{% endif %}
              ">
                "{{ block.settings.testimonial_text }}"
              </blockquote>
              
              <div class="testimonial-author">
                {% if block.settings.author_image != blank %}
                  <div class="author-image">
                    <img src="{{ block.settings.author_image | img_url: '60x60' }}" 
                         alt="{{ block.settings.author_name }}"
                         width="60" 
                         height="60"
                         loading="lazy">
                  </div>
                {% endif %}
                
                <div class="author-details">
                  {% if block.settings.author_name != blank %}
                    <cite class="author-name">{{ block.settings.author_name }}</cite>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      
      {% if section.blocks.size > 1 %}
        <div class="testimonials-atelier__controls">
          <button class="testimonials-atelier__btn testimonials-atelier__btn--prev" id="prev-btn-{{ section.id }}" aria-label="Previous testimonial">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15,18 9,12 15,6"></polyline>
            </svg>
          </button>
          
          <div class="testimonials-atelier__indicators" id="indicators-{{ section.id }}"></div>
          
          <button class="testimonials-atelier__btn testimonials-atelier__btn--next" id="next-btn-{{ section.id }}" aria-label="Next testimonial">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9,6 15,12 9,18"></polyline>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
.section-testimonials-atelier {
  width: auto;
  padding: 2.5rem 0;
  box-sizing: border-box;
  text-align: center;
}

  
  .testimonials-atelier__heading {
    margin-bottom: 2rem;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: 0.02em;
    font-family: {{ section.settings.heading_font }};
    {% if section.settings.heading_case == 'uppercase' %}text-transform: uppercase;{% endif %}
    line-height: {{ section.settings.heading_line_height }};
  }
  
  .testimonials-atelier__carousel {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .testimonials-atelier__container {
    overflow: hidden;
    border-radius: 8px;
    padding: 0;
    margin: 0;
  }
  
  .testimonials-atelier__track {
    display: flex;
    transition: transform 0.5s ease;
    margin: 0;
    padding: 0;
  }
  
  .testimonial-atelier-card {
    flex: 0 0 100%;
    padding: 2rem;
    border-radius: 12px;
    margin: 0 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    min-height: 200px;
    justify-content: center;
    box-sizing: border-box;
  }
  
  .testimonial-quote {
    font-style: italic;
    font-weight: 300;
    margin: 0;
    max-width: 500px;
    position: relative;
    padding: 0 1rem;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .testimonial-quote::before {
    content: '"';
    font-size: 3rem;
    position: absolute;
    left: -1rem;
    top: -0.5rem;
    opacity: 0.3;
    font-family: serif;
  }
  
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  
  .author-image img {
    border-radius: 50%;
    object-fit: cover;
  }
  
  .author-details {
    text-align: left;
  }
  
  .author-name {
    font-weight: 600;
    font-size: 0.95rem;
    font-style: normal;
    display: block;
    margin-bottom: 0;
    color: var(--color-foreground-heading);
  }
  
  .testimonials-atelier__controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  
  .testimonials-atelier__btn {
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    color: currentColor;
  }
  
  .testimonials-atelier__btn:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.1);
  }
  
  .testimonials-atelier__btn:disabled {
    display: none;
    cursor: not-allowed;
  }
  
  .testimonials-atelier__btn svg {
    width: 18px;
    height: 18px;
  }
  
  .testimonials-atelier__indicators {
    display: flex;
    gap: 0.4rem;
  }
  
  .testimonials-atelier__indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .testimonials-atelier__indicator.active {
    background: rgba(255, 255, 255, 0.8);
    transform: scale(1.2);
  }
  
  .testimonials-atelier__indicator:hover {
    background: rgba(255, 255, 255, 0.6);
  }
  
  @media (min-width: 769px) {
    .testimonial-atelier-card {
      flex: 0 0 50%;
    }
  }
  
  @media (min-width: 1201px) {
    .testimonial-atelier-card {
      flex: 0 0 33.333%;
    }
  }
  
  @media (max-width: 768px) {
    .section-testimonials-atelier {
      padding: 2rem 0.75rem;
    }
    
    .testimonials-atelier__heading {
      font-size: 1.75rem;
      margin-bottom: 1.5rem;
    }
    
    .testimonial-quote {
      font-size: 1rem;
      padding: 0 0.75rem;
    }
    
    .testimonial-quote::before {
      left: -0.75rem;
      font-size: 2.5rem;
    }
    
    .testimonial-author {
      flex-direction: column;
      text-align: center;
      gap: 0.5rem;
    }
    
    .author-details {
      text-align: center;
    }
    
    .testimonial-atelier-card {
      margin: 0 0.5rem;
      padding: 1.5rem;
      min-height: 180px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  class AtelierTestimonialCarousel {
    constructor(sectionId) {
      this.sectionId = sectionId;
      this.section = document.getElementById(`testimonials-${sectionId}`);
      if (!this.section) return;
      
      this.track = document.getElementById(`testimonials-track-${sectionId}`);
      this.prevBtn = document.getElementById(`prev-btn-${sectionId}`);
      this.nextBtn = document.getElementById(`next-btn-${sectionId}`);
      this.indicators = document.getElementById(`indicators-${sectionId}`);
      
      if (!this.track) return;
      
      this.cards = this.track.querySelectorAll('.testimonial-atelier-card');
      this.currentIndex = 0;
      this.cardWidth = 0;
      this.visibleCards = 1;
      this.totalSlides = 0;
      this.autoPlayInterval = null;
      
      this.init();
    }

    init() {
      if (this.cards.length <= 1) return;
      
      this.calculateDimensions();
      this.createIndicators();
      this.bindEvents();
      this.updateCarousel();
      
      if (this.totalSlides > 0) {
        this.startAutoPlay();
      }
      
      window.addEventListener('resize', this.debounce(() => {
        this.calculateDimensions();
        this.createIndicators();
        this.updateCarousel();
        this.updateIndicators();
      }, 250));
    }

    calculateDimensions() {
      const containerWidth = this.track.parentElement.offsetWidth;
      
      if (window.innerWidth <= 768) {
        this.visibleCards = 1;
      } else if (window.innerWidth <= 1200) {
        this.visibleCards = 2;
      } else {
        this.visibleCards = 3;
      }
      
      const totalMargins = 0.75 * 2;
      const marginInPx = totalMargins * 16;
      this.cardWidth = (containerWidth + marginInPx) / this.visibleCards;
      this.totalSlides = Math.max(0, this.cards.length - this.visibleCards);
      this.currentIndex = Math.min(this.currentIndex, this.totalSlides);
    }

    createIndicators() {
      if (!this.indicators) return;
      
      this.indicators.innerHTML = '';
      
      if (this.totalSlides > 0) {
        for (let i = 0; i <= this.totalSlides; i++) {
          const indicator = document.createElement('div');
          indicator.className = 'testimonials-atelier__indicator';
          indicator.setAttribute('aria-label', `Go to slide ${i + 1}`);
          indicator.addEventListener('click', () => this.goToSlide(i));
          this.indicators.appendChild(indicator);
        }
      }
    }

    bindEvents() {
      if (this.prevBtn) {
        this.prevBtn.addEventListener('click', () => this.previousSlide());
      }
      
      if (this.nextBtn) {
        this.nextBtn.addEventListener('click', () => this.nextSlide());
      }
      
      this.bindTouchEvents();
      
      this.section.addEventListener('mouseenter', () => this.stopAutoPlay());
      this.section.addEventListener('mouseleave', () => this.startAutoPlay());
      this.section.addEventListener('focusin', () => this.stopAutoPlay());
      this.section.addEventListener('focusout', () => this.startAutoPlay());
    }

    bindTouchEvents() {
      let startX = 0;
      let currentX = 0;
      let isDragging = false;
      
      this.track.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        isDragging = true;
        this.stopAutoPlay();
      }, { passive: true });
      
      this.track.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        currentX = e.touches[0].clientX;
      }, { passive: true });
      
      this.track.addEventListener('touchend', () => {
        if (!isDragging) return;
        isDragging = false;
        
        const diffX = startX - currentX;
        if (Math.abs(diffX) > 50) {
          if (diffX > 0) {
            this.nextSlide();
          } else {
            this.previousSlide();
          }
        }
        
        this.startAutoPlay();
      }, { passive: true });
    }

    updateCarousel() {
      const translateX = -(this.currentIndex * this.cardWidth);
      this.track.style.transform = `translateX(${translateX}px)`;
      
      if (this.prevBtn) {
        this.prevBtn.disabled = this.currentIndex === 0;
      }
      if (this.nextBtn) {
        this.nextBtn.disabled = this.currentIndex >= this.totalSlides;
      }
      
      this.updateIndicators();
    }

    updateIndicators() {
      if (!this.indicators) return;
      
      const indicators = this.indicators.querySelectorAll('.testimonials-atelier__indicator');
      indicators.forEach((indicator, index) => {
        indicator.classList.toggle('active', index === this.currentIndex);
      });
    }

    nextSlide() {
      if (this.currentIndex < this.totalSlides) {
        this.currentIndex++;
      } else {
        this.currentIndex = 0;
      }
      this.updateCarousel();
    }

    previousSlide() {
      if (this.currentIndex > 0) {
        this.currentIndex--;
      } else {
        this.currentIndex = this.totalSlides;
      }
      this.updateCarousel();
    }

    goToSlide(index) {
      this.currentIndex = Math.max(0, Math.min(index, this.totalSlides));
      this.updateCarousel();
      this.stopAutoPlay();
      this.startAutoPlay();
    }

    startAutoPlay() {
      this.stopAutoPlay();
      if (this.cards.length > this.visibleCards && this.totalSlides > 0) {
        this.autoPlayInterval = setInterval(() => {
          this.nextSlide();
        }, 5000);
      }
    }

    stopAutoPlay() {
      if (this.autoPlayInterval) {
        clearInterval(this.autoPlayInterval);
        this.autoPlayInterval = null;
      }
    }

    debounce(func, wait) {
      let timeout;
      return function executedFunction(...args) {
        const later = () => {
          clearTimeout(timeout);
          func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
      };
    }
  }

  new AtelierTestimonialCarousel('{{ section.id }}');
});

if (Shopify.designMode) {
  document.addEventListener('shopify:section:load', function(event) {
    const sectionId = event.detail.sectionId;
    if (event.target.classList.contains('section-testimonials-atelier')) {
      new AtelierTestimonialCarousel(sectionId);
    }
  });
}
</script>

