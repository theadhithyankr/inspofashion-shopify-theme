<script>
  (function() {
    const mobileNav = document.querySelector('.mobile-bottom-nav');
    const navbarHeight = 70;
    let lastScrollPosition = 0;
    const scrollThreshold = 15;
    let ticking = false;
    
    const contactTrigger = document.querySelector('.contact-trigger');
    const contactPopup = document.getElementById('contactPopup');
    const closePopup = document.getElementById('closePopupHandle');

    function setActiveLink() {
      const currentPath = window.location.pathname;
      document.querySelectorAll('.mobile-bottom-nav .nav-item').forEach(item => {
        const href = item.getAttribute('href');
        if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href)))) {
          item.classList.add('active');
        } else {
          item.classList.remove('active');
        }
      });
    }
    
    function setupCartBadge() {
      const cartBadge = document.getElementById('cart-badge');
      
      // Try multiple selectors for cart count
      const cartSelectors = [
        '.cart-bubble__text-count',
        '[data-cart-count]',
        '.cart-count',
        '#cart-count'
      ];
      
      let cartElement = null;
      for (const selector of cartSelectors) {
        cartElement = document.querySelector(selector);
        if (cartElement) break;
      }
      
      if (cartBadge && cartElement) {
        const updateBadge = () => {
          const count = parseInt(cartElement.textContent.trim() || cartElement.dataset.cartCount || '0') || 0;
          if (count > 0) {
            cartBadge.textContent = count > 99 ? '99+' : count;
            cartBadge.style.display = 'flex';
          } else {
            cartBadge.style.display = 'none';
          }
        };
        
        updateBadge();
        
        const observer = new MutationObserver(updateBadge);
        observer.observe(cartElement, { 
          childList: true, 
          subtree: true, 
          attributes: true,
          attributeFilter: ['data-cart-count']
        });
      }
    }

    function handleScroll() {
      const currentScrollPosition = window.pageYOffset || document.documentElement.scrollTop;
      const documentHeight = document.documentElement.scrollHeight;
      const windowHeight = window.innerHeight;
      const bottomOfPage = currentScrollPosition + windowHeight >= documentHeight - navbarHeight;
      
      if (!ticking) {
        window.requestAnimationFrame(function() {
          if (Math.abs(currentScrollPosition - lastScrollPosition) < scrollThreshold) {
            ticking = false;
            return;
          }
          
          // Always maintain body spacing
          document.body.classList.add('nav-space-active');
          
          // Show navbar when at bottom of page or top, hide when scrolling down in middle
          if (currentScrollPosition <= scrollThreshold || bottomOfPage) {
            const wasHidden = mobileNav.classList.contains('hide');
            mobileNav.classList.remove('hide');
            
            // Auto-scroll when navbar appears at bottom to prevent content being covered
            if (wasHidden && bottomOfPage) {
              // Small delay to ensure navbar animation completes
              setTimeout(() => {
                const newScrollPosition = document.documentElement.scrollHeight - window.innerHeight + navbarHeight;
                window.scrollTo({
                  top: newScrollPosition,
                  behavior: 'smooth'
                });
              }, 100);
            }
          } else if (currentScrollPosition > lastScrollPosition && currentScrollPosition > scrollThreshold) {
            mobileNav.classList.add('hide');
          } else {
            mobileNav.classList.remove('hide');
          }

          lastScrollPosition = currentScrollPosition;
          ticking = false;
        });
        
        ticking = true;
      }
    }
    
    function openContactPopup() {
      contactPopup.classList.add('active');
      document.body.style.overflow = 'hidden';
      // Trap focus in popup
      const firstFocusable = contactPopup.querySelector('button, a');
      if (firstFocusable) firstFocusable.focus();
    }
    
    function closeContactPopup() {
      contactPopup.classList.remove('active');
      document.body.style.overflow = '';
      // Return focus to contact trigger
      if (contactTrigger) contactTrigger.focus();
    }
    
    // Keyboard navigation
    function handleKeyDown(e) {
      if (e.key === 'Escape' && contactPopup.classList.contains('active')) {
        closeContactPopup();
      }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
      setActiveLink();
      setupCartBadge();
      
      // Event listeners
      if (contactTrigger) contactTrigger.addEventListener('click', openContactPopup);
      if (closePopup) closePopup.addEventListener('click', closeContactPopup);
      
      // Popup interactions
      contactPopup.addEventListener('click', function(e) {
        if (e.target === contactPopup) closeContactPopup();
      });
      
      // Keyboard navigation
      document.addEventListener('keydown', handleKeyDown);
      
      // Initialize for mobile
      if (window.innerWidth < 768) {
        document.body.classList.add('nav-space-active');
        window.addEventListener('scroll', handleScroll, { passive: true });
      }
      
      // Handle resize
      window.addEventListener('resize', function() {
        if (window.innerWidth < 768) {
          document.body.classList.add('nav-space-active');
          window.addEventListener('scroll', handleScroll, { passive: true });
        } else {
          window.removeEventListener('scroll', handleScroll);
          mobileNav.classList.remove('hide');
          document.body.classList.remove('nav-space-active');
        }
      });
    });
    
    // Handle cart updates from Shopify events
    document.addEventListener('cart:updated', setupCartBadge);
    if (typeof window.Shopify !== 'undefined') {
      document.addEventListener('shopify:cart:update', setupCartBadge);
    }
  })();
</script>